{% assign sorted_tutorials = site.tutorials | where_exp: 'item', 'item.sitemap != false' | sort: 'seo_lastmod' | reverse %}
{% assign newer_tutorial = nil %}
{% assign older_tutorial = nil %}
{% assign previous_item = nil %}
{% assign found_current = false %}

{% for item in sorted_tutorials %}
  {% if found_current and older_tutorial == nil %}
    {% assign older_tutorial = item %}
    {% break %}
  {% endif %}

  {% if item.url == page.url %}
    {% assign newer_tutorial = previous_item %}
    {% assign found_current = true %}
  {% else %}
    {% assign previous_item = item %}
  {% endif %}
{% endfor %}

{% if newer_tutorial or older_tutorial %}
  <div class="tutorial-navigation mt-5" aria-label="教程相邻导航">
    <div class="tutorial-navigation__grid">
      {% if newer_tutorial %}
        {% assign newer_title = newer_tutorial.title | replace: '$', '' | strip_html %}
        <a class="tutorial-navigation__card" href="{{ newer_tutorial.url | relative_url }}" title="{{ newer_title }}">
          <span class="tutorial-navigation__label">上一篇</span>
          <span class="tutorial-navigation__title">{{ newer_title }}</span>
          {% if newer_tutorial.seo_lastmod %}
            <span class="tutorial-navigation__meta">{{ newer_tutorial.seo_lastmod | date: "%Y-%m-%d" }}</span>
          {% endif %}
        </a>
      {% else %}
        <div class="tutorial-navigation__card tutorial-navigation__card--empty">
          <span class="tutorial-navigation__label">上一篇</span>
          <span class="tutorial-navigation__title">已经是最早的一篇</span>
        </div>
      {% endif %}

      {% if older_tutorial %}
        {% assign older_title = older_tutorial.title | replace: '$', '' | strip_html %}
        <a class="tutorial-navigation__card" href="{{ older_tutorial.url | relative_url }}" title="{{ older_title }}">
          <span class="tutorial-navigation__label">下一篇</span>
          <span class="tutorial-navigation__title">{{ older_title }}</span>
          {% if older_tutorial.seo_lastmod %}
            <span class="tutorial-navigation__meta">{{ older_tutorial.seo_lastmod | date: "%Y-%m-%d" }}</span>
          {% endif %}
        </a>
      {% else %}
        <div class="tutorial-navigation__card tutorial-navigation__card--empty">
          <span class="tutorial-navigation__label">下一篇</span>
          <span class="tutorial-navigation__title">已经是最新的一篇</span>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}
